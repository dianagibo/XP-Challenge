<aside class="game-sidebar d-none d-lg-flex">
  <a class="brand" href="/" aria-label="XP Challenge home">
    <span class="brand-mark">XP</span>
    <span>Challenge</span>
  </a>

  <nav class="side-nav" aria-label="Main navigation">
    <a class="nav-link <%= activePage === 'home' ? 'active' : '' %>" href="/">
      <i class="bi bi-grid-fill"></i><span>Home</span>
    </a>
    <a class="nav-link <%= activePage === 'missions' ? 'active' : '' %>" href="<%= currentUser?.role === 'admin_player' ? '/missions/manage' : '/#missions' %>"><i class="bi bi-flag-fill"></i><span>Missions</span></a>
    <% if (['admin_player', 'validator'].includes(currentUser?.role)) { %><a class="nav-link <%= activePage === 'reviews' ? 'active' : '' %>" href="/missions/review"><i class="bi bi-shield-check"></i><span>Reviews</span></a><% } %>
    <% if (['admin_player', 'player'].includes(currentUser?.role)) { %><a class="nav-link <%= activePage === 'catalog' ? 'active' : '' %>" href="/reward-catalog"><i class="bi bi-gift-fill"></i><span>Catalog</span></a><% } %>
    <% if (['admin_player', 'player'].includes(currentUser?.role)) { %><a class="nav-link <%= activePage === 'rewards' ? 'active' : '' %>" href="/rewards"><i class="bi bi-stars"></i><span>History</span></a><% } %>
    <a class="nav-link <%= activePage === 'profile' ? 'active' : '' %>" href="/avatars">
      <i class="bi bi-person-fill"></i><span>Profile</span>
    </a>
  </nav>

  <div class="sidebar-quest" aria-hidden="true">
    <span class="mini-label">Weekly quest</span>
    <strong>2 of 3 goals</strong>
    <div class="progress"><div class="progress-bar" style="width: 66%"></div></div>
    <small>You're almost there!</small>
  </div>
  <form class="logout-form" method="post" action="/auth/logout">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit"><i class="bi bi-box-arrow-left"></i><span>Log out</span></button>
  </form>
</aside>
