  <% if (['admin_player', 'validator'].includes(currentUser?.role)) { %>
    <a class="<%= activePage === 'reviews' ? 'active' : '' %>" href="/missions/review"><i class="bi bi-shield-check"></i><span>Reviews</span></a>
