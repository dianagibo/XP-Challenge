<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header"><div><span class="eyebrow">MOTIVACIÓN A CORTO PLAZO</span><h1>Metas semanales</h1><p><%= currentUser.role === 'admin_player' ? 'Define una meta positiva y celebra la constancia de Sofi.' : 'Sigue tu progreso y desbloquea un bono al alcanzar la meta.' %></p></div><a class="secondary-action" href="/"><i class="bi bi-arrow-left"></i> Volver al inicio</a></header>
    <% if (flash) { %><div class="success-alert"><i class="bi bi-check-circle-fill"></i><%= flash.message %></div><% } %>
    <% if (error) { %><div class="form-alert"><i class="bi bi-exclamation-circle-fill"></i><%= error %></div><% } %>
    <% if (currentUser.role === 'admin_player') { %>
      <details class="catalog-create-card" <%= error ? 'open' : '' %>>
        <summary><span><i class="bi bi-plus-circle-fill"></i>Crear meta semanal</span><small>Objetivo, categoría y bono</small></summary>
        <form class="goal-form" method="post" action="/weekly-goals">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="field field-wide">Nombre de la meta<input name="title" maxlength="100" required value="<%= values.title || '' %>" placeholder="Semana de recuperación"></label>
          <label class="field">Jugadora<select name="player" required><option value="">Selecciona una jugadora</option><% players.forEach((player) => { %><option value="<%= player._id %>" <%= String(values.player || '') === String(player._id) ? 'selected' : '' %>><%= player.name %></option><% }) %></select></label>
          <label class="field">Categoría<select name="category" required><% categories.forEach((category) => { %><option value="<%= category %>" <%= (values.category || 'all') === category ? 'selected' : '' %>><%= labelFor('category', category) %></option><% }) %></select></label>
          <label class="field">Misiones aprobadas<input type="number" name="targetCount" min="1" max="50" required value="<%= values.targetCount || 5 %>"></label>
          <label class="field">Bono de XP<input type="number" name="xpBonus" min="0" max="1000" required value="<%= values.xpBonus ?? 50 %>"></label>
          <label class="field">Bono de monedas<input type="number" name="coinBonus" min="0" max="500" required value="<%= values.coinBonus ?? 20 %>"></label>
          <label class="field">Fecha de inicio<input type="date" name="startDate" min="<%= today %>" required value="<%= values.startDate || today %>"></label>
          <label class="field">Fecha final<input type="date" name="endDate" min="<%= today %>" required value="<%= values.endDate || '' %>"></label>
          <div class="form-actions field-wide"><button class="primary-action" type="submit"><i class="bi bi-bullseye"></i>Crear meta</button></div>
        </form>
      </details>
    <% } %>
    <section class="goal-grid">
      <% goals.forEach((goal) => { %>
        <article class="goal-card <%= goal.status %>">
          <div class="goal-heading"><div><span class="status-chip status-<%= goal.status %>"><%= labelFor('status', goal.status) %></span><h2><%= goal.title %></h2><p><%= labelFor('category', goal.category) %> · <%= goal.startDate %> al <%= goal.endDate %></p></div><i class="bi <%= goal.status === 'completed' ? 'bi-trophy-fill' : 'bi-bullseye' %>"></i></div>
          <% if (currentUser.role === 'admin_player') { %><small class="goal-player">Para <strong><%= goal.player.name %></strong></small><% } %>
          <div class="goal-count"><strong><%= goal.completedCount %></strong><span>de <%= goal.targetCount %> misiones aprobadas</span></div>
          <div class="goal-progress"><div style="width:<%= goal.percent %>%"></div></div>
          <div class="goal-footer"><span><i class="bi bi-lightning-charge-fill"></i> +<%= goal.xpBonus %> XP</span><span><i class="bi bi-coin"></i> +<%= goal.coinBonus %> monedas</span><strong><%= goal.percent %>%</strong></div>
          <% if (goal.status === 'completed') { %><div class="goal-complete"><i class="bi bi-stars"></i> ¡Meta alcanzada! Bono entregado.</div><% } else if (goal.status === 'expired') { %><div class="goal-expired">La semana terminó. No perdiste nada: inténtalo con una nueva meta.</div><% } %>
        </article>
      <% }) %>
      <% if (!goals.length) { %><article class="mission-empty"><i class="bi bi-bullseye"></i><div><h3>Aún no hay metas semanales</h3><p><%= currentUser.role === 'admin_player' ? 'Crea la primera meta positiva para Sofi.' : 'Tu próximo reto semanal aparecerá aquí.' %></p></div></article><% } %>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
