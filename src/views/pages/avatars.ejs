<%- include('../partials/head') %>
<% const selectedAvatar = game.avatars.find((avatar) => avatar.id === game.player.avatar) || game.avatars[0]; %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main avatar-page">
    <header class="topbar">
      <div><span class="eyebrow">TU PERSONAJE</span><h1>Elige tu avatar</h1><p>Elige el personaje que más se parezca a ti.</p></div>
      <a href="/" class="back-button"><i class="bi bi-arrow-left"></i> Volver al inicio</a>
    </header>

    <section class="avatar-stage">
      <div class="stage-copy"><span class="level-chip"><i class="bi bi-stars"></i> Seleccionado actualmente</span><h2><%= selectedAvatar.name %></h2><p><%= selectedAvatar.description %></p></div>
      <%- include('../partials/avatar', { avatar: selectedAvatar, size: 'hero' }) %>
    </section>

    <section class="avatar-section">
      <div class="section-heading"><div><span class="eyebrow">COLECCIÓN DE AVATARES</span><h2>Encuentra tu estilo</h2></div><span class="daily-counter"><strong>3</strong>/6 desbloqueados</span></div>
      <div class="avatar-grid">
        <% game.avatars.forEach((avatar) => { %>
          <form method="post" action="/account/avatar"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="avatar" value="<%= avatar.id %>"><button class="avatar-option <%= avatar.id === game.player.avatar ? 'selected' : '' %> <%= !avatar.unlocked ? 'locked' : '' %>" type="submit" <%= !avatar.unlocked ? 'disabled' : '' %>>
            <% if (!avatar.unlocked) { %><span class="lock-label"><i class="bi bi-lock-fill"></i> Nivel <%= avatar.level %></span><% } %>
            <%- include('../partials/avatar', { avatar, size: 'card' }) %>
            <strong><%= avatar.name %></strong>
            <small><%= avatar.unlocked ? (avatar.id === game.player.avatar ? 'Seleccionado' : 'Toca para elegir') : 'Sigue subiendo de nivel' %></small>
          </button></form>
        <% }) %>
      </div>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
