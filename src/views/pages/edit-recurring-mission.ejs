<%- include('../partials/head') %>
<div class="app-shell"><%- include('../partials/sidebar') %><main class="game-main mission-workspace">
  <header class="workspace-header"><div><span class="eyebrow">HÁBITO RECURRENTE</span><h1>Editar serie</h1><p>Los cambios nunca modifican misiones enviadas, aprobadas, canceladas o archivadas.</p></div><a class="secondary-action" href="/missions/manage">Volver</a></header>
  <% if (error) { %><div class="form-alert"><i class="bi bi-exclamation-circle"></i><%= error %></div><% } %>
  <form class="mission-form" method="post" action="/missions/recurring/<%= values._id %>/edit"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <section class="form-card"><div class="form-card-heading"><span>1</span><div><h2>Detalles y calendario</h2><p>Define qué debe hacerse y cuándo se repite.</p></div></div><div class="form-grid">
      <label class="field field-wide">Título<input name="title" required maxlength="100" value="<%= values.title || '' %>"></label>
      <label class="field field-wide">Descripción<textarea name="description" required maxlength="500" rows="3"><%= values.description || '' %></textarea></label>
      <label class="field">Categoría<select name="category" required><% categories.forEach(item => { %><option value="<%= item.value %>" <%= values.category === item.value ? 'selected' : '' %>><%= item.label %></option><% }) %></select></label>
      <label class="field">Frecuencia<select id="missionFrequency" name="frequency"><option value="daily" <%= values.frequency === 'daily' ? 'selected' : '' %>>Todos los días</option><option value="weekly" <%= values.frequency === 'weekly' ? 'selected' : '' %>>Días seleccionados</option></select></label>
      <label class="field">Fecha de inicio<input type="date" name="startDate" required value="<%= values.startDate || '' %>"></label>
      <label class="field recurring-only">Fecha final <span>(opcional)</span><input type="date" name="endDate" value="<%= values.endDate || '' %>"></label>
      <fieldset id="weekdayField" class="field field-wide validator-field"><legend>Repetir los</legend><div class="validator-options"><% [['1','Lun'],['2','Mar'],['3','Mié'],['4','Jue'],['5','Vie'],['6','Sáb'],['0','Dom']].forEach(([value,label]) => { %><label><input type="checkbox" name="weekdays" value="<%= value %>" <%= [values.weekdays].flat().map(String).includes(value) ? 'checked' : '' %>><span><%= label %></span></label><% }) %></div></fieldset>
      <label class="field field-wide">Instrucciones <span>(opcional)</span><textarea name="instructions" maxlength="1000" rows="3"><%= values.instructions || '' %></textarea></label>
    </div></section>
    <section class="form-card"><div class="form-card-heading"><span>2</span><div><h2>Dificultad y premio</h2></div></div><div class="difficulty-grid"><% Object.entries(rewards).forEach(([difficulty,reward]) => { %><label class="difficulty-option"><input type="radio" name="difficulty" value="<%= difficulty %>" <%= values.difficulty === difficulty ? 'checked' : '' %> required><span><strong><%= labelFor('difficulty',difficulty) %></strong><small>+<%= reward.xp %> XP · <%= reward.coins %> monedas</small></span></label><% }) %></div><div class="reward-fields"><label class="field">XP<input id="xpReward" type="number" name="xpReward" min="1" max="500" required value="<%= values.xpReward %>"></label><label class="field">Monedas<input id="coinReward" type="number" name="coinReward" min="0" max="100" required value="<%= values.coinReward %>"></label></div></section>
    <section class="form-card"><div class="form-card-heading"><span>3</span><div><h2>Validación y alcance</h2></div></div><fieldset class="field validator-field"><legend>¿Quién puede validar?</legend><div class="validator-options"><% validators.forEach(item => { const checked=[values.validators].flat().map(v=>String(v._id||v)).includes(String(item.user._id)); %><label><input type="checkbox" name="validators" value="<%= item.user._id %>" <%= checked?'checked':'' %>><span><%= item.user.name %></span></label><% }) %></div></fieldset><fieldset class="field validator-field"><legend>¿Qué hacemos con las próximas misiones pendientes ya creadas?</legend><div class="validator-options"><label><input type="radio" name="updatePending" value="yes" <%= values.updatePending !== 'no' ? 'checked' : '' %>><span>Actualizar con esta configuración</span></label><label><input type="radio" name="updatePending" value="no" <%= values.updatePending === 'no' ? 'checked' : '' %>><span>Conservar como están</span></label></div></fieldset><p>Las misiones que Sofi ya envió y las que tienen historial nunca serán modificadas.</p></section>
    <div class="form-actions"><a class="secondary-action" href="/missions/manage">Cancelar</a><button class="primary-action" type="submit">Guardar cambios</button></div>
  </form>
</main></div>
<script>window.missionRewards=<%- JSON.stringify(rewards) %>;</script><script src="/js/create-mission.js"></script>
<%- include('../partials/footer') %>
