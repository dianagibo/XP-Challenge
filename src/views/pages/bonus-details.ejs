<%- include('../partials/head') %>
<div class="app-shell"><%- include('../partials/sidebar') %><main class="game-main mission-workspace">
  <a class="secondary-action" href="/bonuses"><i class="bi bi-arrow-left"></i> Volver</a>
  <% if (flash) { %><div class="alert <%= flash.type === 'success' ? 'alert-success' : 'alert-danger' %>"><%= flash.message %></div><% } %>
  <section class="bonus-celebration <%= bonus.status === 'voided' ? 'voided' : '' %>"><div class="celebration-stars">✦ ✨ ✦</div><i class="bi bi-award-fill"></i><span class="eyebrow"><%= bonus.status === 'voided' ? 'RECONOCIMIENTO ANULADO' : '¡ESTE MOMENTO ES TUYO!' %></span><h1><%= bonus.title %></h1><p><%= bonus.message %></p><div class="bonus-prizes"><strong>+<%= bonus.xpAmount %> XP</strong><strong><i class="bi bi-coin"></i> +<%= bonus.coinAmount %> monedas</strong></div><small>Entregado por <%= bonus.grantedBy?.name %> · <%= formatDate(bonus.createdAt, true) %></small></section>
  <% if (bonus.status === 'voided') { %><section class="history-card"><h2>Trazabilidad</h2><p>Anulado por <%= bonus.voidedBy?.name %> el <%= formatDate(bonus.voidedAt, true) %>.</p><p><strong>Motivo:</strong> <%= bonus.voidReason %></p></section><% } %>
  <% if (currentUser.role === 'admin_player') { %><div class="bonus-admin-grid"><section class="history-card"><h2>Editar texto</h2><form method="post" action="/bonuses/<%= bonus._id %>/edit" class="stacked-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Título<input name="title" maxlength="80" value="<%= bonus.title %>" required></label><label>Mensaje<textarea name="message" maxlength="300" required><%= bonus.message %></textarea></label><button class="secondary-action" type="submit">Guardar texto</button></form></section>
  <% if (bonus.status === 'active') { %><section class="history-card danger-zone"><h2>Anular reconocimiento</h2><p>Se descontarán exactamente los XP y monedas entregados, dejando el registro original.</p><form method="post" action="/bonuses/<%= bonus._id %>/void" class="stacked-form" onsubmit="return confirm('¿Seguro que deseas anular este reconocimiento?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Motivo<input name="reason" maxlength="200" required></label><button class="danger-action" type="submit">Anular con trazabilidad</button></form></section><% } %></div><% } %>
</main></div><%- include('../partials/footer') %>
