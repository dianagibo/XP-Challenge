<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>

  <main class="game-main">
    <header class="topbar">
      <div>
        <span class="eyebrow"><%= new Intl.DateTimeFormat('es-CO', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'America/Bogota' }).format(new Date()).toUpperCase() %></span>
        <h1>¡Hola, <%= game.player.name %>! <span class="wave">✦</span></h1>
        <p>Tu próximo nivel está más cerca de lo que imaginas.</p>
      </div>
      <div class="top-actions">
        <div class="coin-pill"><i class="bi bi-coin"></i><strong><%= game.player.coins %></strong></div>
        <a class="icon-button notification-bell" href="/notifications" aria-label="Notificaciones<%= unreadNotificationCount > 0 ? `: ${unreadNotificationCount} sin leer` : '' %>">
          <i class="bi bi-bell<%= unreadNotificationCount > 0 ? '-fill' : '' %>"></i>
          <% if (unreadNotificationCount > 0) { %>
            <strong class="notification-badge"><%= unreadNotificationCount > 99 ? '99+' : unreadNotificationCount %></strong>
          <% } %>
        </a>
        <a href="/avatars" class="avatar-link" aria-label="Abrir perfil">
          <%- include('../partials/avatar', { avatar: game.avatars.find(item => item.id === game.player.avatar), size: 'sm' }) %>
        </a>
      </div>
    </header>

    <section class="hero-card">
      <div class="hero-copy">
        <span class="level-chip"><i class="bi bi-stars"></i> Nivel <%= game.player.level %></span>
        <h2><%= game.player.title %></h2>
        <p>Cada misión hace más fuerte a tu personaje.</p>
        <div class="xp-row">
          <span><strong><%= game.player.currentXp %></strong> / <%= game.player.nextLevelXp %> XP</span>
          <span>Te faltan <%= game.player.nextLevelXp - game.player.currentXp %> XP para subir de nivel</span>
        </div>
        <div class="progress hero-progress">
          <div class="progress-bar" style="width: <%= Math.round((game.player.currentXp / game.player.nextLevelXp) * 100) %>%"></div>
        </div>
      </div>
      <div class="hero-avatar-wrap">
        <div class="orbit orbit-one"></div><div class="orbit orbit-two"></div>
        <%- include('../partials/avatar', { avatar: game.avatars.find(item => item.id === game.player.avatar), size: 'hero' }) %>
        <span class="float-star star-one">✦</span><span class="float-star star-two">★</span>
      </div>
    </section>

    <div class="dashboard-grid">
      <section class="main-column">
        <div class="section-heading" id="missions">
          <div><span class="eyebrow">AVENTURA DE HOY</span><h2>Tus misiones</h2></div>
          <% if (canCreateMissions) { %><a class="text-action" href="/missions/create"><i class="bi bi-plus-lg"></i> <%= currentUser.role === 'player' ? 'Retar a Diana' : 'Crear misión' %></a><% } %>
        </div>
        <% if (flash) { %><div class="success-alert"><i class="bi bi-check-circle-fill"></i><%= flash.message %></div><% } %>
        <% if (activities.length) { %>
          <div class="mission-list real-missions">
          <% activities.forEach((mission) => { %>
            <article class="mission-card <%= mission.status === 'pending_validation' ? 'is-awaiting' : '' %>">
              <div class="mission-icon icon-purple"><i class="bi bi-flag-fill"></i></div>
              <div class="mission-copy"><span class="mission-category"><%= labelFor('category', mission.category) %> · <%= labelFor('difficulty', mission.difficulty) %><%= mission.recurringMission ? ' · recurrente' : '' %></span><h3><%= mission.title %></h3><p><%= mission.description %><br><small>Fecha límite: <%= formatDate(mission.dueDate) %></small></p></div>
              <div class="mission-reward"><span>+<%= mission.xpReward %> XP</span><span><i class="bi bi-coin"></i> <%= mission.coinReward %></span></div>
              <% if (['pending_acceptance', 'assigned', 'changes_requested'].includes(mission.status)) { %>
                <a class="round-action stretched-link" href="/missions/<%= mission._id %>" aria-label="Abrir <%= mission.title %>"><i class="bi bi-chevron-right"></i></a>
              <% } else { %>
                <span class="status-chip status-<%= mission.status %>"><%= labelFor('status', mission.status) %></span>
              <% } %>
            </article>
          <% }) %>
          </div>
        <% } else if (canCreateMissions) { %>
          <article class="mission-empty"><i class="bi bi-stars"></i><div><h3>¿Lista para crear la primera misión?</h3><p><%= currentUser.role === 'player' ? 'Reta a Diana y conviertan el progreso en un juego de las dos.' : 'Asígnale a Sofi un reto con propósito y elige sus premios.' %></p></div><a class="primary-action" href="/missions/create"><%= currentUser.role === 'player' ? 'Retar a Diana' : 'Crear misión' %></a></article>
        <% } else { %>
          <article class="mission-empty"><i class="bi bi-flag"></i><div><h3>Aún no tienes misiones</h3><p>Tu próxima aventura aparecerá aquí.</p></div></article>
        <% } %>

      </section>

      <aside class="right-column">
        <article class="streak-card">
          <div class="fire"><i class="bi bi-fire"></i></div>
          <div><span class="eyebrow">RACHA DE DÍAS HÁBILES</span><h2><%= game.streak.count %> <small>de 5 días</small></h2><p>Premio: <strong>25 XP y 5 monedas</strong></p></div>
          <div class="streak-days">
            <% ['1','2','3','4','5'].forEach((day, index) => { const isStreakDay = index < game.streak.count; %>
              <span class="<%= isStreakDay ? 'done' : '' %>"><i class="bi <%= isStreakDay ? 'bi-check' : '' %>"></i><small><%= day %></small></span>
            <% }) %>
          </div>
        </article>

        <% if (activeGoal) { %><a class="team-card dashboard-goal" href="/weekly-goals">
          <div class="team-header"><span><i class="bi bi-bullseye"></i></span><small><%= activeGoal.endDate %></small></div>
          <span class="eyebrow">META SEMANAL</span>
          <h2><%= activeGoal.title %></h2>
          <p><%= activeGoal.completedCount %> de <%= activeGoal.targetCount %> misiones aprobadas</p>
          <div class="team-progress-label"><span>Progreso semanal</span><strong><%= activeGoal.percent %>%</strong></div>
          <div class="progress"><div class="progress-bar" style="width: <%= activeGoal.percent %>%"></div></div>
          <div class="team-footer"><strong><i class="bi bi-stars"></i> +<%= activeGoal.xpBonus %> XP · <i class="bi bi-coin"></i> +<%= activeGoal.coinBonus %></strong></div>
        </a><% } else { %><a class="team-card dashboard-goal" href="/weekly-goals">
          <div class="team-header"><span><i class="bi bi-bullseye"></i></span></div>
          <span class="eyebrow">META SEMANAL</span>
          <h2>No hay una meta activa</h2>
          <p><%= canManageMissions ? 'Crea una meta corta para celebrar el progreso de Sofi esta semana.' : 'Tu próxima meta semanal aparecerá aquí.' %></p>
        </a><% } %>

        <a class="profile-teaser" href="/avatars">
          <div><span class="eyebrow">HAZLO A TU MANERA</span><h3>Elige tu avatar</h3><p>Desbloquea nuevos personajes al subir de nivel.</p></div>
          <i class="bi bi-arrow-up-right"></i>
        </a>
      </aside>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
