<%- include('../partials/head') %>
<% const icons = { gift: 'bi-gift-fill', movie: 'bi-film', game: 'bi-controller', treat: 'bi-cup-straw', outing: 'bi-map-fill', choice: 'bi-stars' }; %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header">
      <div><span class="eyebrow"><%= isAdmin ? 'RECOMPENSAS FAMILIARES' : 'USA TUS MONEDAS' %></span><h1><%= isAdmin ? 'Catálogo de recompensas' : 'Elige tu próxima recompensa' %></h1><p><%= isAdmin ? 'Crea recompensas significativas y lleva el control de cada entrega.' : `Tienes ${rewards.coins} monedas disponibles.` %></p></div>
      <a class="secondary-action" href="/rewards"><i class="bi bi-clock-history"></i> Historial de XP y monedas</a>
    </header>
    <% if (flash) { %><div class="<%= flash.type === 'error' ? 'form-alert' : 'success-alert' %>"><i class="bi <%= flash.type === 'error' ? 'bi-exclamation-circle' : 'bi-check-circle-fill' %>"></i><%= flash.message %></div><% } %>
    <% if (isAdmin) { %>
      <details class="catalog-create-card" <%= !catalog.length ? 'open' : '' %>>
        <summary><span><i class="bi bi-plus-circle-fill"></i> Agregar una recompensa</span><small>Crea una opción que Sofi pueda canjear con sus monedas.</small></summary>
        <form method="post" action="/reward-catalog" class="catalog-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="field">Nombre de la recompensa<input name="name" required maxlength="80" placeholder="Noche de película"></label>
          <label class="field">Costo en monedas<input name="coinCost" type="number" required min="1" step="1" placeholder="20"></label>
          <label class="field">Ícono<select name="icon" required><option value="gift">Regalo</option><option value="movie">Película</option><option value="game">Juego</option><option value="treat">Antojo</option><option value="outing">Salida</option><option value="choice">Elección de Sofi</option></select></label>
          <label class="field field-wide">Descripción<textarea name="description" rows="2" maxlength="300" placeholder="Qué incluye esta recompensa"></textarea></label>
          <div class="form-actions field-wide"><button class="primary-action" type="submit"><i class="bi bi-plus-lg"></i> Agregar al catálogo</button></div>
        </form>
      </details>
    <% } else { %><section class="catalog-balance"><i class="bi bi-coin"></i><div><span>Saldo disponible</span><strong><%= rewards.coins %> monedas</strong></div></section><% } %>
    <section class="catalog-section">
      <div class="section-heading"><div><span class="eyebrow">CATÁLOGO</span><h2><%= isAdmin ? 'Recompensas disponibles' : 'Elige algo que valga la pena ganar' %></h2></div></div>
      <% if (catalog.length) { %><div class="catalog-grid">
        <% catalog.forEach((reward) => { const canAfford = rewards.coins >= reward.coinCost; %><article class="catalog-card <%= reward.isActive ? '' : 'is-inactive' %>">
          <div class="catalog-icon"><i class="bi <%= icons[reward.icon] || icons.gift %>"></i></div>
          <div class="catalog-copy"><div class="catalog-title"><h3><%= reward.name %></h3><span><i class="bi bi-coin"></i> <%= reward.coinCost %></span></div><p><%= reward.description || 'Una recompensa especial por una misión bien hecha.' %></p></div>
          <% if (isAdmin) { %><div class="catalog-admin-actions"><% if (reward.isActive) { %><form method="post" action="/reward-catalog/<%= reward._id %>/redeem"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="primary-action catalog-action" type="submit" <%= canAfford ? '' : 'disabled' %>><i class="bi bi-bag-heart-fill"></i> <%= canAfford ? 'Canjear para mí' : 'Sin monedas suficientes' %></button></form><% } %><form method="post" action="/reward-catalog/<%= reward._id %>/toggle"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="secondary-action catalog-action" type="submit"><i class="bi <%= reward.isActive ? 'bi-pause-circle' : 'bi-play-circle' %>"></i> <%= reward.isActive ? 'Desactivar' : 'Activar' %></button></form></div>
          <% } else { %><form method="post" action="/reward-catalog/<%= reward._id %>/redeem"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="primary-action catalog-action" type="submit" <%= canAfford ? '' : 'disabled' %>><i class="bi bi-bag-heart-fill"></i> <%= canAfford ? 'Canjear recompensa' : 'Sigue ganando' %></button></form><% } %>
        </article><% }) %>
      </div><% } else { %><article class="manage-empty"><span><i class="bi bi-gift"></i></span><div><h2>Aún no hay recompensas</h2><p><%= isAdmin ? 'Agrega la primera recompensa para motivar a Sofi.' : 'Diana está preparando tus primeras recompensas.' %></p></div></article><% } %>
    </section>
    <section class="history-card redemption-section">
      <div class="section-heading"><div><span class="eyebrow">CANJES</span><h2><%= isAdmin ? 'Pendientes de entrega' : 'Mis recompensas canjeadas' %></h2></div></div>
      <% if (redemptions.length) { %><div class="reward-history">
        <% redemptions.forEach((redemption) => { %><article class="redemption-row">
          <div class="mission-icon <%= redemption.status === 'delivered' ? 'icon-mint' : 'icon-purple' %>"><i class="bi <%= redemption.status === 'delivered' ? 'bi-check-lg' : icons[redemption.reward?.icon] || icons.gift %>"></i></div>
          <div class="redemption-copy"><strong><%= redemption.reward?.name || 'Recompensa' %></strong><p><%= isAdmin ? `${redemption.player?.name || 'Jugadora'} · ` : '' %><%= formatDate(redemption.createdAt, true) %> · <%= redemption.coinCost %> monedas</p></div>
          <span class="status-chip status-<%= redemption.status %>"><%= redemption.status === 'pending_delivery' ? 'Pendiente de entrega' : 'Entregada' %></span>
          <% if (isAdmin && redemption.status === 'pending_delivery') { %><form method="post" action="/reward-catalog/redemptions/<%= redemption._id %>/deliver"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="approve-action" type="submit"><i class="bi bi-check2"></i> Marcar como entregada</button></form><% } %>
        </article><% }) %>
      </div><% } else { %><article class="mission-empty"><i class="bi bi-bag-heart"></i><div><h3>Aún no hay canjes</h3><p><%= isAdmin ? 'Las nuevas solicitudes aparecerán aquí para su entrega.' : 'Tus recompensas canjeadas aparecerán aquí.' %></p></div></article><% } %>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
