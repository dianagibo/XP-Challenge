<%- include('../partials/head') %><div class="app-shell"><%- include('../partials/sidebar') %><main class="game-main mission-workspace"><header class="workspace-header"><div><span class="eyebrow">HISTORIAL</span><h1>Misiones archivadas</h1><p>Consulta lo finalizado sin alterar premios ni progreso.</p></div><a class="secondary-action" href="/missions/manage">Volver a activas</a></header>
<% if (!activities.length) { %><section class="manage-empty"><span><i class="bi bi-archive"></i></span><h2>Aún no hay misiones archivadas</h2></section><% } else { %><section class="manage-list"><% activities.forEach(mission => { %><article class="manage-card"><div class="mission-icon icon-purple"><i class="bi bi-archive-fill"></i></div><div class="manage-copy"><span class="mission-category"><%= labelFor('category',mission.category) %></span><h2><%= mission.title %></h2><p><%= mission.description %></p><div class="manage-meta"><span><%= mission.assignedTo.name %></span><span>Archivada: <%= formatDate(mission.archivedAt) %></span></div></div><div class="manage-reward"><strong>+<%= mission.xpReward %> XP</strong><span><%= mission.coinReward %> monedas</span><span class="status-chip status-<%= mission.status %>"><%= labelFor('status',mission.status) %></span></div></article><% }) %></section><% } %>
</main></div><%- include('../partials/footer') %>
