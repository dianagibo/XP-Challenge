<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header">
      <div><span class="eyebrow">MI AVENTURA</span><h1>Mi progreso</h1><p>Celebra lo que has construido. Perder un día nunca elimina XP, monedas ni logros.</p></div>
      <a class="secondary-action" href="/"><i class="bi bi-arrow-left"></i> Volver al inicio</a>
    </header>
    <section class="progress-stats-grid">
      <article class="progress-stat-card purple"><i class="bi bi-stars"></i><span>Total XP</span><strong><%= progress.stats.totalXp %></strong><small>Nivel <%= progress.stats.level %> · <%= progress.stats.title %></small></article>
      <article class="progress-stat-card orange"><i class="bi bi-fire"></i><span>Racha actual</span><strong><%= progress.stats.currentStreak %> días</strong><small>Mejor racha: <%= progress.stats.bestStreak %> días</small></article>
      <article class="progress-stat-card green"><i class="bi bi-check-circle-fill"></i><span>Misiones aprobadas</span><strong><%= progress.stats.approvedMissions %></strong><small>Cada aprobación cuenta</small></article>
    </section>
    <section class="history-card level-progress-card">
      <div class="section-heading"><div><span class="eyebrow">PRÓXIMO NIVEL</span><h2><%= progress.stats.currentXp %> / <%= progress.stats.nextLevelXp %> XP</h2></div><strong><%= progress.stats.nextLevelXp - progress.stats.currentXp %> XP por conseguir</strong></div>
      <div class="progress"><div class="progress-bar" style="width: <%= Math.round((progress.stats.currentXp / progress.stats.nextLevelXp) * 100) %>%"></div></div>
    </section>
    <section class="history-card">
      <div class="section-heading"><div><span class="eyebrow">LOGROS</span><h2>Tu colección de insignias</h2></div><span><%= progress.achievements.filter(item => item.unlocked).length %> / <%= progress.achievements.length %> desbloqueados</span></div>
      <div class="achievement-grid">
        <% progress.achievements.forEach((achievement) => { %>
          <article class="achievement-card <%= achievement.unlocked ? 'unlocked' : 'locked' %>">
            <div class="achievement-icon"><i class="bi <%= achievement.unlocked ? achievement.icon : 'bi-lock-fill' %>"></i></div>
            <div><h3><%= achievement.name %></h3><p><%= achievement.description %></p><small><%= achievement.unlocked ? `Obtenido el ${formatDate(achievement.unlockedAt)}` : 'Aún por descubrir' %></small></div>
          </article>
        <% }) %>
      </div>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
