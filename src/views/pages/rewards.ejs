<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header">
      <div><span class="eyebrow">TU PROGRESO</span><h1>Historial de XP y monedas</h1><p>Cada misión aprobada deja una huella permanente en tu aventura.</p></div>
      <a class="secondary-action" href="/"><i class="bi bi-arrow-left"></i> Volver al inicio</a>
    </header>
    <section class="reward-summary-grid">
      <article class="reward-summary-card xp"><i class="bi bi-stars"></i><div><span>Total XP</span><strong><%= rewards.totalXp %></strong><small>Nivel <%= rewards.level %> · <%= rewards.currentXp %> / <%= rewards.nextLevelXp %> XP</small></div></article>
      <article class="reward-summary-card coins"><i class="bi bi-coin"></i><div><span>Monedas disponibles</span><strong><%= rewards.coins %></strong><small>Listas para próximas recompensas</small></div></article>
    </section>
    <section class="history-card">
      <div class="section-heading"><div><span class="eyebrow">MOVIMIENTOS</span><h2>Ganancias recientes</h2></div></div>
      <% if (transactions.length) { %><div class="reward-history">
        <% transactions.forEach((transaction) => { %><article class="reward-history-row">
          <div class="mission-icon icon-purple"><i class="bi bi-trophy-fill"></i></div>
          <div><strong><%= transaction.sourceActivity?.title || transaction.sourceBonus?.title || 'Reconocimiento especial' %></strong><p><%= transaction.type === 'mission_approved' ? 'Aprobada' : transaction.type === 'manual_bonus_voided' ? 'Bono anulado' : 'Bono entregado' %> por <%= transaction.grantedBy?.name || 'una persona validadora' %> · <%= formatDate(transaction.createdAt, true) %></p></div>
          <div class="history-amount"><strong><%= transaction.xpAmount >= 0 ? '+' : '' %><%= transaction.xpAmount %> XP</strong><span><i class="bi bi-coin"></i> <%= transaction.coinAmount >= 0 ? '+' : '' %><%= transaction.coinAmount %></span></div>
        </article><% }) %>
      </div><% } else { %>
        <article class="mission-empty"><i class="bi bi-stars"></i><div><h3>Tu primer premio te está esperando</h3><p>Completa una misión y consigue su aprobación para iniciar tu historial.</p></div></article>
      <% } %>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
