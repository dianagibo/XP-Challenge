<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header">
      <div><span class="eyebrow">CONTROL DE MISIONES</span><h1>Administrar misiones</h1><p>Sigue cada responsabilidad desde su asignación hasta la aprobación.</p></div>
      <div class="top-actions"><a class="secondary-action" href="/missions/archive"><i class="bi bi-archive"></i> Archivadas</a><a class="primary-action" href="/missions/create"><i class="bi bi-plus-lg"></i> Crear misión</a></div>
    </header>
    <% if (flash) { %><div class="<%= flash.type === 'error' ? 'form-alert' : 'success-alert' %>"><i class="bi bi-<%= flash.type === 'error' ? 'exclamation-circle' : 'check-circle-fill' %>"></i><%= flash.message %></div><% } %>
    <% if (recurringMissions.length) { %>
      <section class="form-card">
        <div class="form-card-heading"><span><i class="bi bi-arrow-repeat"></i></span><div><h2>Series recurrentes</h2><p>Edita, pausa o finaliza hábitos sin alterar el historial completado.</p></div></div>
        <div class="manage-list">
          <% recurringMissions.forEach((series) => { %>
            <article class="manage-card">
              <div class="mission-icon icon-purple"><i class="bi bi-arrow-repeat"></i></div>
              <div class="manage-copy"><div><span class="mission-category"><%= labelFor('frequency', series.frequency) %><%= series.frequency === 'weekly' ? ' · ' + series.weekdays.map(day => ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'][day]).join(', ') : '' %></span><h2><%= series.title %></h2></div><p>Inicia <%= series.startDate %><%= series.endDate ? ' · Finaliza ' + series.endDate : ' · Sin fecha final' %><br><small><%= series.endedAt ? 'Serie finalizada' : series.isActive ? (series.nextOccurrence ? 'Próxima misión: ' + series.nextOccurrence : 'No quedan fechas programadas') : 'La generación está pausada' %></small></p></div>
              <div class="manage-reward"><span class="status-chip <%= series.endedAt ? 'status-canceled' : series.isActive ? 'status-approved' : 'status-changes_requested' %>"><%= series.endedAt ? 'Finalizada' : series.isActive ? 'Activa' : 'Pausada' %></span><div class="mission-manage-actions">
                <% if (!series.endedAt) { %><a class="secondary-action compact-action" href="/missions/recurring/<%= series._id %>/edit">Editar</a><form method="post" action="/missions/recurring/<%= series._id %>/status"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="action" value="<%= series.isActive ? 'pause' : 'resume' %>"><button class="secondary-action compact-action" type="submit"><%= series.isActive ? 'Pausar' : 'Reactivar' %></button></form><form method="post" action="/missions/recurring/<%= series._id %>/end"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="danger-action compact-action" type="submit" onclick="return confirm('¿Finalizar esta serie definitivamente? Las misiones pendientes futuras dejarán de aparecer y el historial se conservará.')">Finalizar</button></form><% } %>
              </div></div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>
    <% if (!activities.length) { %>
      <section class="manage-empty"><span><i class="bi bi-map"></i></span><h2>Tu tablero de misiones está listo</h2><p>Crea la primera responsabilidad y aparecerá de inmediato en el tablero de Sofi.</p><a class="primary-action" href="/missions/create">Crear la primera misión</a></section>
    <% } else { %>
      <section class="manage-list">
        <% activities.forEach((mission) => { %>
          <article class="manage-card">
            <div class="mission-icon icon-purple"><i class="bi bi-flag-fill"></i></div>
            <div class="manage-copy"><div><span class="mission-category"><%= labelFor('category', mission.category) %> · <%= labelFor('difficulty', mission.difficulty) %><%= mission.recurringMission ? ' · recurrente' : '' %></span><h2><%= mission.title %></h2></div><p><%= mission.description %></p><div class="manage-meta"><span><i class="bi bi-person"></i><%= mission.assignedTo.name %></span><span><i class="bi bi-calendar3"></i><%= formatDate(mission.dueDate) %></span><span><i class="bi bi-shield-check"></i><%= mission.validators.map(item => item.name).join(' o ') %></span></div></div>
            <div class="manage-reward"><strong>+<%= mission.xpReward %> XP</strong><span><i class="bi bi-coin"></i> <%= mission.coinReward %></span><span class="status-chip status-<%= mission.status %>"><%= labelFor('status', mission.status) %></span><div class="mission-manage-actions">
              <% if (['assigned','changes_requested'].includes(mission.status)) { %><a class="secondary-action compact-action" href="/missions/<%= mission._id %>/edit">Editar</a><% } %>
              <% if (['assigned','changes_requested','pending_validation'].includes(mission.status)) { %><form method="post" action="/missions/<%= mission._id %>/cancel"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="danger-action compact-action" type="submit" onclick="return confirm('¿Cancelar esta misión? No se eliminará el historial.')">Cancelar</button></form><% } %>
              <% if (['approved','canceled'].includes(mission.status)) { %><form method="post" action="/missions/<%= mission._id %>/archive"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="secondary-action compact-action" type="submit" onclick="return confirm('¿Mover esta misión al historial archivado?')">Archivar</button></form><% } %>
            </div></div>
          </article>
        <% }) %>
      </section>
    <% } %>
  </main>
</div>
<%- include('../partials/footer') %>
