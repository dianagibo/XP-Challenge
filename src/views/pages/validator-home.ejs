<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main">
    <header class="topbar">
      <div><span class="eyebrow">CENTRO DE VALIDACIÓN</span><h1>¡Hola, <%= currentUser.name %>!</h1><p>Aquí ayudarás a celebrar las misiones completadas.</p></div>
      <form class="mobile-logout" method="post" action="/auth/logout"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="icon-button" type="submit" aria-label="Cerrar sesión"><i class="bi bi-box-arrow-right"></i></button></form>
    </header>
    <% if (flash) { %><div class="success-alert"><i class="bi bi-check-circle-fill"></i><%= flash.message %></div><% } %>
    <section class="hero-card validator-hero">
      <div class="hero-copy"><span class="level-chip"><i class="bi bi-shield-check"></i> Validadora</span><h2><%= activities.length ? `${activities.length} ${activities.length === 1 ? 'misión pendiente' : 'misiones pendientes'}` : 'No hay misiones pendientes' %></h2><p><%= activities.length ? 'Sofi está lista para que revises y celebres su esfuerzo.' : 'Cuando Sofi complete una misión asignada a ti, aparecerá aquí.' %></p></div>
      <div class="validator-icon"><i class="bi bi-check2-circle"></i></div>
    </section>
    <section class="validator-next"><span class="eyebrow">COLA DE VALIDACIÓN</span><h2>Revisar misiones completadas</h2><p>Aprueba el trabajo o solicita un pequeño ajuste con comentarios claros.</p><a class="primary-action validator-cta" href="/missions/review">Abrir revisiones <i class="bi bi-arrow-right"></i></a></section>
  </main>
</div>
<%- include('../partials/footer') %>
