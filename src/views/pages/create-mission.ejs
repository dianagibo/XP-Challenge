<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header">
      <div><span class="eyebrow"><%= isSharedChallenge ? 'RETO FAMILIAR' : 'NUEVA AVENTURA' %></span><h1><%= isSharedChallenge ? 'Retar a un familiar' : 'Crear una misión' %></h1><p><%= isSharedChallenge ? 'Elige a quién quieres retar y premia su esfuerzo.' : 'Convierte una responsabilidad en un reto claro y motivador.' %></p></div>
      <a class="secondary-action" href="/missions/manage"><i class="bi bi-arrow-left"></i> Volver a misiones</a>
    </header>

    <% if (error) { %><div class="form-alert"><i class="bi bi-exclamation-circle"></i><%= error %></div><% } %>

    <form class="mission-form" method="post" action="/missions">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <section class="form-card">
        <div class="form-card-heading"><span>1</span><div><h2>Detalles de la misión</h2><p>Haz que el objetivo sea fácil de entender.</p></div></div>
        <div class="form-grid">
          <label class="field field-wide">Título<input name="title" required maxlength="100" value="<%= values.title || '' %>" placeholder="Completar la tarea de matemáticas"></label>
          <label class="field field-wide">Descripción<textarea name="description" required maxlength="500" rows="3" placeholder="¿Qué debe lograr la persona asignada?"><%= values.description || '' %></textarea></label>
          <label class="field">Categoría<select name="category" required><option value="">Elige una categoría</option><% categories.forEach((category) => { %><option value="<%= category.value %>" <%= values.category === category.value ? 'selected' : '' %>><%= category.label %></option><% }) %></select></label>
          <% if (isSharedChallenge) { %><input type="hidden" name="frequency" value="once"><% } else { %><label class="field">Frecuencia<select id="missionFrequency" name="frequency"><option value="once" <%= (values.frequency || 'once') === 'once' ? 'selected' : '' %>>Una vez</option><option value="daily" <%= values.frequency === 'daily' ? 'selected' : '' %>>Todos los días</option><option value="weekly" <%= values.frequency === 'weekly' ? 'selected' : '' %>>Días seleccionados</option></select></label><% } %>
          <label class="field">Fecha de inicio<input type="date" name="startDate" min="<%= minimumDate %>" required value="<%= values.startDate || values.dueDate || minimumDate %>"></label>
          <% if (!isSharedChallenge) { %><label class="field recurring-only">Fecha final <span>(opcional)</span><input type="date" name="endDate" min="<%= minimumDate %>" value="<%= values.endDate || '' %>"></label>
          <fieldset id="weekdayField" class="field field-wide validator-field"><legend>Repetir los</legend><div class="validator-options"><% [['1','Lun'],['2','Mar'],['3','Mié'],['4','Jue'],['5','Vie'],['6','Sáb'],['0','Dom']].forEach(([value,label]) => { %><label><input type="checkbox" name="weekdays" value="<%= value %>" <%= [values.weekdays].flat().map(String).includes(value) ? 'checked' : '' %>><span><%= label %></span></label><% }) %></div></fieldset><% } %>
          <label class="field field-wide">Instrucciones adicionales <span>(opcional)</span><textarea name="instructions" maxlength="1000" rows="2" placeholder="Agrega una recomendación o criterio para completarla"><%= values.instructions || '' %></textarea></label>
        </div>
      </section>

      <section class="form-card">
        <div class="form-card-heading"><span>2</span><div><h2>Reto y premios</h2><p>La dificultad sugiere una cantidad equilibrada de XP y monedas.</p></div></div>
        <div class="difficulty-grid">
          <% Object.entries(rewards).filter(([difficulty]) => !isSharedChallenge || difficulty !== 'epic').forEach(([difficulty, reward]) => { %>
            <label class="difficulty-option"><input type="radio" name="difficulty" value="<%= difficulty %>" <%= (values.difficulty || 'easy') === difficulty ? 'checked' : '' %> required><span><strong><%= labelFor('difficulty', difficulty) %></strong><small>+<%= reward.xp %> XP · <%= reward.coins %> monedas</small></span></label>
          <% }) %>
        </div>
        <% if (isSharedChallenge) { %>
        <div class="reward-fields">
          <p><i class="bi bi-info-circle"></i> Elige una dificultad y el premio se asignará automáticamente. Los XP y las monedas no se pueden modificar.</p>
        </div>
        <% } else { %>
        <div class="reward-fields">
          <label class="field">Premio en XP<input id="xpReward" type="number" name="xpReward" min="1" max="<%= isSharedChallenge ? 50 : 500 %>" required value="<%= values.xpReward || rewards[values.difficulty || 'easy'].xp %>"></label>
          <label class="field">Premio en monedas<input id="coinReward" type="number" name="coinReward" min="0" max="<%= isSharedChallenge ? 10 : 100 %>" required value="<%= values.coinReward || rewards[values.difficulty || 'easy'].coins %>"></label>
          <p><i class="bi bi-info-circle"></i> Los XP aumentan tu progreso y no se gastan. Las monedas se pueden cambiar por recompensas.</p>
        </div>
        <% } %>
      </section>

      <section class="form-card">
        <div class="form-card-heading"><span>3</span><div><h2>Personas</h2><p>Elige al participante y quién puede validar el resultado.</p></div></div>
        <div class="form-grid">
          <label class="field field-wide">Asignar a<select name="assignedTo" required><option value="">Elige un participante</option><% players.forEach((item) => { %><option value="<%= item.user._id %>" <%= String(values.assignedTo || '') === String(item.user._id) ? 'selected' : '' %>><%= item.user.name %> (@<%= item.user.username %>)</option><% }) %></select></label>
          <fieldset class="field field-wide validator-field"><legend>¿Quién puede validar?</legend><div class="validator-options"><% validators.forEach((item) => { const checked = isSharedChallenge || [values.validators].flat().map(String).includes(String(item.user._id)); %><label><input type="checkbox" name="validators" value="<%= item.user._id %>" <%= checked ? 'checked' : '' %> <%= isSharedChallenge ? 'disabled' : '' %>><span><i class="bi bi-shield-check"></i><%= item.user.name %><%= isSharedChallenge ? ' (tú revisarás el reto)' : '' %></span></label><% }) %></div></fieldset>
        </div>
      </section>

      <div class="form-actions"><a class="secondary-action" href="/missions/manage">Cancelar</a><button class="primary-action" type="submit"><i class="bi bi-stars"></i> Crear misión</button></div>
    </form>
  </main>
</div>
<script>window.missionRewards = <%- JSON.stringify(rewards) %>;</script>
<script src="/js/create-mission.js"></script>
<%- include('../partials/footer') %>
