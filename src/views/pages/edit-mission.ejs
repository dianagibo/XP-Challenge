<%- include('../partials/head') %><div class="app-shell"><%- include('../partials/sidebar') %><main class="game-main mission-workspace">
<header class="workspace-header"><div><span class="eyebrow">AJUSTAR MISIÓN</span><h1>Editar misión</h1><p>Los cambios aplican únicamente a esta misión.</p></div><a class="secondary-action" href="/missions/manage">Volver</a></header>
<% if (error) { %><div class="form-alert"><i class="bi bi-exclamation-circle"></i><%= error %></div><% } %>
<form class="mission-form" method="post" action="/missions/<%= values._id %>/edit"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
<section class="form-card"><div class="form-card-heading"><span>1</span><div><h2>Detalles</h2><p>La persona asignada y la recurrencia se conservan.</p></div></div><div class="form-grid">
<label class="field field-wide">Título<input name="title" required maxlength="100" value="<%= values.title || '' %>"></label>
<label class="field field-wide">Descripción<textarea name="description" required maxlength="500" rows="3"><%= values.description || '' %></textarea></label>
<label class="field">Categoría<select name="category" required><% categories.forEach(item => { %><option value="<%= item.value %>" <%= values.category === item.value ? 'selected' : '' %>><%= item.label %></option><% }) %></select></label>
<label class="field">Fecha límite<input type="date" name="dueDate" min="<%= minimumDate %>" required value="<%= values.dueDate || '' %>"></label>
<label class="field field-wide">Instrucciones<textarea name="instructions" maxlength="1000" rows="3"><%= values.instructions || '' %></textarea></label></div></section>
<section class="form-card"><div class="form-card-heading"><span>2</span><div><h2>Dificultad y premio</h2></div></div><div class="difficulty-grid"><% Object.entries(rewards).forEach(([difficulty,reward]) => { %><label class="difficulty-option"><input type="radio" name="difficulty" value="<%= difficulty %>" <%= values.difficulty === difficulty ? 'checked' : '' %> required><span><strong><%= labelFor('difficulty',difficulty) %></strong><small>+<%= reward.xp %> XP · <%= reward.coins %> monedas</small></span></label><% }) %></div><div class="reward-fields"><label class="field">XP<input id="xpReward" type="number" name="xpReward" min="1" max="500" required value="<%= values.xpReward %>"></label><label class="field">Monedas<input id="coinReward" type="number" name="coinReward" min="0" max="100" required value="<%= values.coinReward %>"></label></div></section>
<section class="form-card"><div class="form-card-heading"><span>3</span><div><h2>Validación</h2></div></div><fieldset class="field validator-field"><legend>¿Quién puede validar?</legend><div class="validator-options"><% validators.forEach(item => { const checked=[values.validators].flat().map(v=>String(v._id||v)).includes(String(item.user._id)); %><label><input type="checkbox" name="validators" value="<%= item.user._id %>" <%= checked?'checked':'' %>><span><%= item.user.name %></span></label><% }) %></div></fieldset></section>
<div class="form-actions"><a class="secondary-action" href="/missions/manage">Cancelar</a><button class="primary-action" type="submit">Guardar cambios</button></div></form></main></div><script>window.missionRewards=<%- JSON.stringify(rewards) %>;</script><script src="/js/create-mission.js"></script><%- include('../partials/footer') %>
