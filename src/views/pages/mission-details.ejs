<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="game-main mission-workspace">
    <header class="workspace-header">
      <div>
        <span class="eyebrow">DETALLES DE LA MISIÓN</span>
        <h1><%= activity.title %></h1>
        <p>Revisa la misión y envíala cuando estés lista.</p>
      </div>
      <a class="secondary-action" href="/"><i class="bi bi-arrow-left"></i> Volver a misiones</a>
    </header>

    <% if (error) { %><div class="form-alert"><i class="bi bi-exclamation-circle-fill"></i><%= error %></div><% } %>

    <section class="mission-detail-card">
      <div class="mission-detail-heading">
        <div class="mission-icon icon-purple"><i class="bi bi-flag-fill"></i></div>
        <div>
          <span class="mission-category"><%= activity.category.replace('_', ' ') %> · <%= activity.difficulty %></span>
          <h2><%= activity.title %></h2>
          <p><%= activity.description %></p>
        </div>
        <div class="detail-rewards"><strong>+<%= activity.xpReward %> XP</strong><span><i class="bi bi-coin"></i> <%= activity.coinReward %></span></div>
      </div>

      <div class="mission-detail-grid">
        <div><span>Fecha límite</span><strong><i class="bi bi-calendar3"></i> <%= formatDate(activity.dueDate) %></strong></div>
        <div><span>Personas que validan</span><strong><i class="bi bi-shield-check"></i> <%= activity.validators.map(item => item.name).join(' o ') %></strong></div>
      </div>

      <% if (activity.instructions) { %>
        <div class="mission-instructions"><span>Instrucciones</span><p><%= activity.instructions %></p></div>
      <% } %>

      <% if (activity.status === 'changes_requested') { %>
        <div class="review-feedback changes"><i class="bi bi-arrow-repeat"></i><div><strong>Ajustes solicitados</strong><p><%= activity.reviewNote %></p></div></div>
      <% } %>

      <% if (['assigned', 'changes_requested'].includes(activity.status)) { %>
        <form class="submission-form" method="post" action="/missions/<%= activity._id %>/submit">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="field">
            Nota de cumplimiento <span>Opcional · Cuéntale a quien valida cómo te fue.</span>
            <textarea name="completionNote" rows="4" maxlength="500" placeholder="Completé esta misión..."><%= values.completionNote || '' %></textarea>
          </label>
          <div class="submission-callout"><i class="bi bi-info-circle"></i><span>Los XP y las monedas se sumarán cuando Diana o mamá aprueben tu misión.</span></div>
          <div class="form-actions"><a class="secondary-action" href="/">Aún no</a><button class="primary-action" type="submit"><i class="bi bi-send-check"></i> Enviar para aprobación</button></div>
        </form>
      <% } else if (activity.status === 'pending_validation') { %>
        <div class="awaiting-card"><i class="bi bi-hourglass-split"></i><div><strong>Esperando aprobación</strong><p>Esta misión ya fue enviada para revisión.</p></div></div>
      <% } else { %>
        <div class="review-feedback approved"><i class="bi bi-check-circle-fill"></i><div><strong>Misión aprobada</strong><p>Ganaste <%= activity.xpReward %> XP y <%= activity.coinReward %> monedas. Ya aparecen en tu saldo.</p></div></div>
      <% } %>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
