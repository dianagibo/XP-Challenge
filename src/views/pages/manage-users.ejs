<%- include('../partials/head') %>
<div class="app-shell"><%- include('../partials/sidebar') %><main class="game-main mission-workspace">
  <header class="workspace-header"><div><span class="eyebrow">FAMILIA Y PERMISOS</span><h1>Usuarios de la familia</h1><p>Invita familiares y decide cómo participan en el juego.</p></div></header>
  <% if (flash) { %><div class="success-alert"><i class="bi bi-check-circle-fill"></i><%= flash.message %></div><% } %>
  <% if (error) { %><div class="form-alert"><i class="bi bi-exclamation-circle-fill"></i><%= error %></div><% } %>
  <section class="form-card"><div class="form-card-heading"><span><i class="bi bi-person-plus-fill"></i></span><div><h2>Crear usuario</h2><p>La contraseña será temporal y deberá cambiarse al iniciar sesión.</p></div></div>
    <form method="post" action="/family-users" class="form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="field">Nombre<input name="name" maxlength="80" required value="<%= values.name || '' %>"></label><label class="field">Usuario<input name="username" minlength="3" maxlength="40" pattern="[a-zA-Z0-9._-]+" required value="<%= values.username || '' %>"></label>
      <label class="field">Contraseña temporal<input type="password" name="temporaryPassword" minlength="10" required></label><label class="field">Rol<select name="role" required><option value="player">Participante</option><option value="validator">Acompañante</option><option value="player_validator">Participante y acompañante</option></select></label>
      <fieldset class="field field-wide validator-field"><legend>Permisos</legend><div class="validator-options"><% Object.entries(permissionLabels).forEach(([key,label]) => { %><label><input type="checkbox" name="<%= key %>" <%= defaults.player[key] ? 'checked' : '' %>><span><%= label %></span></label><% }) %></div></fieldset>
      <div class="form-actions field-wide"><button class="primary-action" type="submit"><i class="bi bi-person-plus"></i> Crear usuario</button></div>
    </form>
  </section>
  <section class="form-card"><div class="form-card-heading"><span><i class="bi bi-people-fill"></i></span><div><h2>Miembros actuales</h2><p>Desactivar conserva todo el progreso y el historial.</p></div></div><div class="manage-list">
    <% accounts.forEach(item => { %><article class="manage-card"><div class="manage-copy"><h2><%= item.user.name %></h2><p>@<%= item.user.username %> · <%= item.role === 'admin_player' ? 'Administradora' : item.role === 'player' ? 'Participante' : item.role === 'validator' ? 'Acompañante' : 'Participante y acompañante' %><%= item.user.lastLoginAt ? ` · Último ingreso ${formatDate(item.user.lastLoginAt, true)}` : ' · Aún no ingresa' %></p></div>
      <% if (item.role !== 'admin_player') { %><details class="field-wide"><summary class="secondary-action">Editar acceso</summary><form method="post" action="/family-users/<%= item.user._id %>" class="form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="field">Nombre<input name="name" value="<%= item.user.name %>" required></label><label class="field">Rol<select name="role"><% roles.forEach(role => { %><option value="<%= role %>" <%= item.role === role ? 'selected' : '' %>><%= role === 'player' ? 'Participante' : role === 'validator' ? 'Acompañante' : 'Participante y acompañante' %></option><% }) %></select></label><fieldset class="field field-wide validator-field"><legend>Permisos</legend><div class="validator-options"><% Object.entries(permissionLabels).forEach(([key,label]) => { %><label><input type="checkbox" name="<%= key %>" <%= item.permissions[key] ? 'checked' : '' %>><span><%= label %></span></label><% }) %></div></fieldset><label class="field field-wide"><input type="checkbox" name="isActive" <%= item.isActive && item.user.isActive ? 'checked' : '' %>> Cuenta activa</label><button class="primary-action" type="submit">Guardar cambios</button></form>
      <form method="post" action="/family-users/<%= item.user._id %>/password" class="inline-password-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="password" name="temporaryPassword" minlength="10" placeholder="Nueva contraseña temporal" required><button class="secondary-action" type="submit">Restablecer</button></form></details><% } %>
    </article><% }) %>
  </div></section>
</main></div><%- include('../partials/footer') %>
