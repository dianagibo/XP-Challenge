<%- include('../partials/head') %>
<main class="auth-page">
  <section class="auth-card">
    <a class="brand auth-brand" href="/auth/login"><span class="brand-mark">XP</span><span>XP Challenge</span></a>
    <div class="auth-heading">
      <span class="eyebrow">¡QUÉ BUENO VERTE!</span>
      <h1>¿Lista para tu próxima aventura?</h1>
      <p>Ingresa para seguir ganando XP, monedas y nuevos logros.</p>
    </div>
    <% if (error) { %>
      <div class="auth-error" role="alert"><i class="bi bi-exclamation-circle"></i><span><%= error %></span></div>
    <% } %>
    <form class="auth-form" method="post" action="/auth/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="username">Usuario</label>
      <div class="input-wrap"><i class="bi bi-person"></i><input id="username" name="username" type="text" value="<%= username %>" autocomplete="username" required autofocus></div>
      <label for="password">Contraseña</label>
      <div class="input-wrap"><i class="bi bi-lock"></i><input id="password" name="password" type="password" autocomplete="current-password" required></div>
      <button class="auth-submit" type="submit">Comenzar aventura <i class="bi bi-arrow-right"></i></button>
    </form>
    <p class="auth-note"><i class="bi bi-shield-check"></i> Tu aventura familiar es privada y está protegida.</p>
  </section>
  <aside class="auth-art" aria-hidden="true">
    <div class="auth-orbit orbit-a"></div><div class="auth-orbit orbit-b"></div>
    <div class="login-level"><span>NIVEL</span><strong>03</strong></div>
    <span class="login-star ls-one">✦</span><span class="login-star ls-two">★</span><span class="login-star ls-three">✦</span>
    <h2>Pequeñas misiones.<br>Grandes logros.</h2>
  </aside>
</main>
<%- include('../partials/footer') %>
